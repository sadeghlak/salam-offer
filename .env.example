# Copy this file to .env on the host and replace values.
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,salam-offer.titanapp.dev,YOUR_DOMAIN_OR_IP
DJANGO_CSRF_TRUSTED_ORIGINS=https://salam-offer.titanapp.dev
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_SECURE=1

# Production PostgreSQL. Leave empty locally to use SQLite.
DATABASE_URL=
DATABASE_SSL_REQUIRE=0

# SQLite fallback for local/dev when DATABASE_URL is empty.
SQLITE_PATH=/app/data/db.sqlite3

PORT=8000
WEB_CONCURRENCY=2
WEB_TIMEOUT=120

BASALAM_TEXT_SEARCH_URL=https://services.basalam.com/web/v1/search/product/search
BASALAM_IMAGE_SEARCH_URL=https://services.basalam.com/web/v1/search/image/search
BASALAM_PRODUCT_DETAIL_URL_TEMPLATE=https://openapi.basalam.com/v1/products/{product_id}
CHEAPER_ANALYSIS_TEXT_SEARCH_SIZE=20
CHEAPER_ANALYSIS_IMAGE_SEARCH_SIZE=20
CHEAPER_ANALYSIS_DETAIL_FETCH_LIMIT=40
CHEAPER_ANALYSIS_MIN_SIMILARITY=0.60
CHEAPER_ANALYSIS_MIN_CHEAPER_DELTA=1
CHEAPER_ANALYSIS_REQUEST_TIMEOUT_SECONDS=15
CHEAPER_ANALYSIS_MAX_BATCH_SIZE=3
CHEAPER_ANALYSIS_STALE_MINUTES=30
CHEAPER_ANALYSIS_ENABLE_IMAGE_SEARCH=1
CHEAPER_ANALYSIS_WEIGHT_EMBEDDING=0.65
CHEAPER_ANALYSIS_WEIGHT_CATEGORY=0.20
CHEAPER_ANALYSIS_WEIGHT_WEIGHT=0.15
